<Page x:Class="Royal_Blueberry_Dictionary.View.Pages.MyWordsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:uc="clr-namespace:Royal_Blueberry_Dictionary.View.User_Control"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="1200"
      Title="MyWordsPage"
      Background="{DynamicResource MainBackground}">

    <Page.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ToolButtonActive}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="24,12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-2" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SearchBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Padding" Value="24,12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WordItemHover}" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-2" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TagDropdownButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource SearchBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="25"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WordItemHover}" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-2" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AlphabetButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource SearchBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource TextColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WordItemHover}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ToolButtonActive}" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ToolButtonActive}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="Opacity" Value="0.4" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TagRowButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Padding" Value="15,12" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="2"
                    CornerRadius="20"
                    Padding="40,30"
                    Margin="0,0,0,30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.1" Color="Black" />
                </Border.Effect>

                <StackPanel>
                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="📚"
                                       FontSize="48"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextColor}"
                                       Margin="0,0,15,0" />
                            <TextBlock Text="My Words"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextColor}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0"
                                    Command="{Binding CreateTagCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏷️" FontSize="16" Margin="0,0,8,0" />
                                    <TextBlock Text="Create New Tag" FontSize="16" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ClearButtonStyle}" Command="{Binding OpenRemoveTagDialogCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="❌" FontSize="16" Margin="0,0,8,0" />
                                    <TextBlock Text="Delete Tag" FontSize="16" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Background="{DynamicResource CardBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="2"
                            CornerRadius="15"
                            Padding="20"
                            Margin="0,0,0,25">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TotalWords}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource ButtonColor}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Total Words"
                                           FontSize="15"
                                           Foreground="{DynamicResource TextColor}"
                                           Opacity="0.8"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TotalTags}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource ButtonColor}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Total Tags"
                                           FontSize="15"
                                           Foreground="{DynamicResource TextColor}"
                                           Opacity="0.8"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding WordsThisWeek}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource ButtonColor}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Words This Week"
                                           FontSize="15"
                                           Foreground="{DynamicResource TextColor}"
                                           Opacity="0.8"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding WordsThisMonth}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource ButtonColor}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Words This Month"
                                           FontSize="15"
                                           Foreground="{DynamicResource TextColor}"
                                           Opacity="0.8"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <WrapPanel Grid.Column="0" HorizontalAlignment="Left">
                            <Button Style="{StaticResource FilterChipStyle}" Command="{Binding ClearFiltersCommand}">
                                <TextBlock Text="All" />
                            </Button>

                            <Button Style="{StaticResource FilterChipStyle}"
                                    Command="{Binding FilterByPartOfSpeechCommand}"
                                    CommandParameter="noun">
                                <TextBlock Text="Noun" />
                            </Button>

                            <Button Style="{StaticResource FilterChipStyle}"
                                    Command="{Binding FilterByPartOfSpeechCommand}"
                                    CommandParameter="verb">
                                <TextBlock Text="Verb" />
                            </Button>

                            <Button Style="{StaticResource FilterChipStyle}"
                                    Command="{Binding FilterByPartOfSpeechCommand}"
                                    CommandParameter="adjective">
                                <TextBlock Text="Adjective" />
                            </Button>
                        </WrapPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Grid Margin="0,0,10,0">
                                <ToggleButton x:Name="AlphabetDropdownToggle"
                                              Style="{StaticResource TagDropdownButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔤" FontSize="14" Margin="0,0,8,0" />
                                        <TextBlock Text="Filter By Letter" Margin="0,0,8,0" />
                                        <TextBlock Text="▼" FontSize="12" />
                                    </StackPanel>
                                </ToggleButton>

                                <Popup IsOpen="{Binding IsChecked, ElementName=AlphabetDropdownToggle}"
                                       PlacementTarget="{Binding ElementName=AlphabetDropdownToggle}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True">
                                    <Border Background="{DynamicResource CardBackground}"
                                            BorderBrush="{DynamicResource BorderColor}"
                                            BorderThickness="2"
                                            CornerRadius="15"
                                            Padding="20">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.2" Color="Black" />
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock Text="Select Letter"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TextColor}"
                                                       Margin="0,0,0,15" />
                                            <ItemsControl ItemsSource="{Binding AlphabetItems}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="7" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding DisplayText}"
                                                                Style="{StaticResource AlphabetButtonStyle}"
                                                                Command="{Binding DataContext.PickAlphabetCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding Letter}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>

                            <Grid>
                                <ToggleButton x:Name="TagsDropdownToggle"
                                              Style="{StaticResource TagDropdownButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏷️" FontSize="14" Margin="0,0,8,0" />
                                        <TextBlock Text="Filter By Tag" Margin="0,0,8,0" />
                                        <TextBlock Text="▼" FontSize="12" />
                                    </StackPanel>
                                </ToggleButton>

                                <Popup IsOpen="{Binding IsChecked, ElementName=TagsDropdownToggle}"
                                       PlacementTarget="{Binding ElementName=TagsDropdownToggle}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True">
                                    <Border Background="{DynamicResource CardBackground}"
                                            BorderBrush="{DynamicResource BorderColor}"
                                            BorderThickness="2"
                                            CornerRadius="15"
                                            Padding="15"
                                            Width="320"
                                            MaxHeight="400">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.2" Color="Black" />
                                        </Border.Effect>
                                        <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding TagRows}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Style="{StaticResource TagRowButtonStyle}"
                                                                Margin="0,0,0,8"
                                                                HorizontalAlignment="Stretch"
                                                                Command="{Binding DataContext.FilterByTagCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding Tag}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding Tag.Icon, FallbackValue=📚}"
                                                                           FontSize="20"
                                                                           Margin="0,0,10,0"
                                                                           VerticalAlignment="Center" />
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{Binding Tag.Name}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource TextColor}"
                                                                               FontSize="14" />
                                                                    <TextBlock FontSize="13"
                                                                               Foreground="{DynamicResource TextColor}"
                                                                               Opacity="0.7">
                                                                        <Run Text="{Binding WordCount, Mode=OneWay}" />
                                                                        <Run Text=" words" />
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1">
                <Border Background="Transparent"
                        Padding="15,0"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="{Binding CurrFilter}"
                                       FontSize="48"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource ToolButtonActive}"
                                       Margin="0,0,15,0" />
                            <TextBlock Text="{Binding WordsCount}"
                                       FontSize="20"
                                       Foreground="{DynamicResource TextColor}"
                                       Opacity="0.6"
                                       VerticalAlignment="Bottom"
                                       Margin="0,0,0,8" />
                        </StackPanel>
                        <Border Height="3"
                                Background="{DynamicResource ToolButtonActive}"
                                CornerRadius="2"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding FilteredWords}" Margin="0,30,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <uc:WordDefinitionCard DataSource="{Binding}"
                                                   Margin="0,0,0,10"
                                                   DeleteCommand="{Binding DataContext.DeleteWordEntryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   FavoriteCommand="{Binding DataContext.FavoriteCommand, RelativeSource={RelativeSource AncestorType=Page}}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
