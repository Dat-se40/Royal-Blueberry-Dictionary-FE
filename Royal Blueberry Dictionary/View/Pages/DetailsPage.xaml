<Page x:Class="Royal_Blueberry_Dictionary.View.Pages.DetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:conv="clr-namespace:Royal_Blueberry_Dictionary.Converters"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="880"
      Title="DetailsPage"
      Background="{DynamicResource MainBackground}">

    <Page.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibility"/>
        <conv:StringNullOrEmptyToVisibilityConverter x:Key="StringToVisibility"/>
        <conv:TakeFirstNEnumerableConverter x:Key="TakeFirstFive"/>

        <Style x:Key="MeaningCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MeaningBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MeaningBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="22,20"/>
        </Style>

        <Style x:Key="PosBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ToolButtonActive}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource WordItemBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WordItemHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PhoneticChipStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource WordItemBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WordItemHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarIconButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
        <Grid Margin="28,24,28,36" MaxWidth="920" HorizontalAlignment="Center">
            <Border Style="{StaticResource CardStyle}" Padding="0" BorderThickness="1">
                <StackPanel>

                    <!-- Header -->
                    <Border Background="{DynamicResource ToolbarBackground}"
                            BorderBrush="{DynamicResource ToolbarBorder}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="16,16,0,0"
                            Padding="28,22">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding WordTitle}"
                                               FontSize="36" FontWeight="Bold"
                                               Foreground="{DynamicResource TextColor}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding WordDetail.Phonetic}"
                                               FontSize="17" Opacity="0.75"
                                               Foreground="{DynamicResource TextColor}"
                                               Margin="0,6,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Button Content="❤️" Style="{StaticResource ToolbarIconButtonStyle}"
                                            Command="{Binding ToggleFavoriteCommand}"/>
                                    <Button Content="🏷️" Style="{StaticResource ToolbarIconButtonStyle}"
                                            Command="{Binding SaveWordCommand}"/>
                                    <Button Content="📝" Style="{StaticResource ToolbarIconButtonStyle}"
                                            Command="{Binding OpenNoteCommand}"/>
                                    <Button Content="🔗" Style="{StaticResource ToolbarIconButtonStyle}"
                                            Command="{Binding ShareWordCommand}"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,18,0,0">
                                <Border Style="{StaticResource PhoneticChipStyle}" Margin="0,0,10,0"
                                        ToolTip="US pronunciation">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding PlayAudioUsCommand}"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <TextBlock Text="US" FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource ButtonColor}"/>
                                        <TextBlock Text="{Binding PhoneticUs}" FontSize="15"
                                                   Foreground="{DynamicResource TextColor}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource PhoneticChipStyle}"
                                        ToolTip="UK pronunciation">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding PlayAudioUkCommand}"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <TextBlock Text="UK" FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource ButtonColor}"/>
                                        <TextBlock Text="{Binding PhoneticUk}" FontSize="15"
                                                   Foreground="{DynamicResource TextColor}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Illustration -->
                    <Border Margin="28,24,28,0"
                            Visibility="{Binding HasWordImage, Converter={StaticResource BooleanToVisibility}}">
                        <Border Width="520" Height="280" HorizontalAlignment="Center"
                                CornerRadius="16" ClipToBounds="True"
                                Background="{DynamicResource WordItemBackground}"
                                BorderBrush="{DynamicResource BorderColor}" BorderThickness="2">
                            <Image Source="{Binding WordImage}" Stretch="UniformToFill"/>
                        </Border>
                    </Border>

                    <!-- Meanings -->
                    <ItemsControl ItemsSource="{Binding WordDetail.Meanings}" Margin="28,24,28,28">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource MeaningCardStyle}">
                                    <StackPanel>
                                        <Border Style="{StaticResource PosBadgeStyle}">
                                            <TextBlock Text="{Binding PartOfSpeech}"
                                                       Foreground="White" FontWeight="Bold" FontSize="14"/>
                                        </Border>

                                        <ItemsControl ItemsSource="{Binding Definitions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,18">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="•" FontSize="18" FontWeight="Bold"
                                                                       Foreground="{DynamicResource ButtonColor}"
                                                                       Margin="0,0,10,0" VerticalAlignment="Top"/>
                                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                                       FontSize="17" LineHeight="24"
                                                                       Foreground="{DynamicResource TextColor}"/>
                                                        </StackPanel>

                                                        <Border Margin="28,12,0,0" Padding="14,12" CornerRadius="10"
                                                                BorderThickness="3,0,0,0"
                                                                BorderBrush="{DynamicResource ExampleBorder}"
                                                                Background="{DynamicResource ExampleBackground}"
                                                                Visibility="{Binding Example, Converter={StaticResource StringToVisibility}}">
                                                            <TextBlock FontStyle="Italic" Opacity="0.88"
                                                                       TextWrapping="Wrap" FontSize="15"
                                                                       Foreground="{DynamicResource TextColor}"
                                                                       Text="{Binding Example}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Đồng nghĩa / trái nghĩa: tối đa 5 mục, một hàng ngang -->
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Synonyms" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ButtonColor}" Margin="0,0,0,8"/>
                                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                              VerticalScrollBarVisibility="Disabled"
                                                              Padding="0,2,0,4">
                                                    <ItemsControl ItemsSource="{Binding Synonyms, Converter={StaticResource TakeFirstFive}, ConverterParameter=5}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button Content="{Binding}"
                                                                        Margin="0,0,8,0"
                                                                        Style="{StaticResource TagButtonStyle}"
                                                                        Command="{Binding DataContext.SearchRelatedWordCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                        CommandParameter="{Binding}"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Antonyms" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ButtonColor}" Margin="0,0,0,8"/>
                                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                              VerticalScrollBarVisibility="Disabled"
                                                              Padding="0,2,0,4">
                                                    <ItemsControl ItemsSource="{Binding Antonyms, Converter={StaticResource TakeFirstFive}, ConverterParameter=5}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button Content="{Binding}"
                                                                        Margin="0,0,8,0"
                                                                        Style="{StaticResource TagButtonStyle}"
                                                                        Command="{Binding DataContext.SearchRelatedWordCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                        CommandParameter="{Binding}"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
