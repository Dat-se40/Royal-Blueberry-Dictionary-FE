<Page x:Class="Royal_Blueberry_Dictionary.View.Pages.DetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Royal_Blueberry_Dictionary.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="DetailsPage"
      Background="{DynamicResource MainBackground}">

    <Page.Resources>
        <Style x:Key="MeaningCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MeaningBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MeaningBorder}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ToolButtonActive}"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        <Style x:Key="PhoneticButtonStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource WordItemBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WordItemHover}"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-2"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="{Binding Source={StaticResource BorderColor}, Path=Color}"
                                        Opacity="0.2"
                                        BlurRadius="12"
                                        ShadowDepth="4"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="{DynamicResource WordItemBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WordItemHover}"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-2"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Border Style="{StaticResource CardStyle}" Padding="0" BorderThickness="2">
                <StackPanel>

                    <Border Background="{DynamicResource ToolbarBackground}"
                            BorderBrush="{DynamicResource ToolbarBorder}"
                            BorderThickness="0,0,0,2"
                            CornerRadius="16,16,0,0"
                            Padding="30,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding WordDetail.Word}"
                                           FontSize="35" FontWeight="Bold"
                                           Foreground="{DynamicResource TextColor}"
                                           Margin="0,0,30,0"/>

                                <StackPanel Orientation="Horizontal">
                                    <Border Style="{StaticResource PhoneticButtonStyle}" Margin="0,0,10,0"
                                            ToolTip="US Pronunciation">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" 
                                                          Command="{Binding PlayAudioCommand}" CommandParameter="US"/>
                                        </Border.InputBindings>
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel>
                                                <TextBlock Text="US 🇺🇸" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ButtonColor}"/>
                                                <TextBlock Text="{Binding WordDetail.Phonetic}" FontSize="16" Foreground="{DynamicResource TextColor}"/>
                                            </StackPanel>
                                            <ContentControl Margin="10,0,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource PhoneticButtonStyle}" ToolTip="UK Pronunciation">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" 
                                                          Command="{Binding PlayAudioCommand}" CommandParameter="UK"/>
                                        </Border.InputBindings>
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel>
                                                <TextBlock Text="UK 🇬🇧" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ButtonColor}"/>
                                                <TextBlock Text="{Binding WordDetail.Phonetic}" FontSize="16" Foreground="{DynamicResource TextColor}"/>
                                            </StackPanel>
                                            <ContentControl  Margin="10,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="❤️" Style="{StaticResource ActionButtonStyle}" Command="{Binding ToggleFavoriteCommand}"/>
                                <Button Content="🏷️" Style="{StaticResource ActionButtonStyle}" Command="{Binding SaveWordCommand}"/>
                                <Button Content="📝" Style="{StaticResource ActionButtonStyle}" Command="{Binding OpenNoteCommand}"/>
                                <Button Content="🔗" Style="{StaticResource ActionButtonStyle}" Command="{Binding ShareWordCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Width="500" Height="300" CornerRadius="15" ClipToBounds="True"
        Background="{DynamicResource WordItemBackground}"
        BorderBrush="{DynamicResource BorderColor}" BorderThickness="3">
                        <Image Source="{Binding WordImage}" Stretch="Uniform" />
                    </Border>

                    <ItemsControl ItemsSource="{Binding WordDetail.Meanings}" Margin="30,0,30,30">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource MeaningCardStyle}">
                                    <StackPanel>
                                        <Border Style="{StaticResource BadgeStyle}">
                                            <TextBlock Text="{Binding PartOfSpeech}" Foreground="White" FontWeight="Bold"/>
                                        </Border>

                                        <ItemsControl ItemsSource="{Binding Definitions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,15">
                                                        <TextBlock TextWrapping="Wrap" FontSize="16" Foreground="{DynamicResource TextColor}">
                                                            <Run Text="• " FontWeight="Bold" Foreground="{DynamicResource ButtonColor}"/>
                                                            <Run Text="{Binding Text}"/>
                                                        </TextBlock>

                                                        <Border Margin="25,10,0,0" Padding="12" CornerRadius="8"
                                                                BorderThickness="4,0,0,0" BorderBrush="{DynamicResource ExampleBorder}"
                                                                Background="{DynamicResource ExampleBackground}">
                                                            <TextBlock Text="{Binding Example, StringFormat='&quot;{0}&quot;'}" 
                                                                       FontStyle="Italic" Opacity="0.8" TextWrapping="Wrap"/>
                                                        </Border>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <UniformGrid Columns="2" Margin="0,10,0,0">
                                            <StackPanel Margin="0,0,10,0">
                                                <TextBlock Text="Synonyms" FontWeight="Bold" Opacity="0.6" Margin="0,0,0,5"/>
                                                <ItemsControl ItemsSource="{Binding Synonyms}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Content="{Binding}" Margin="0,0,5,5" 
                                                                    Style="{StaticResource TagButtonStyle}"
                                                                    Command="{Binding DataContext.SearchRelatedCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel>
                                                <TextBlock Text="Antonyms" FontWeight="Bold" Opacity="0.6" Margin="0,0,0,5"/>
                                                <ItemsControl ItemsSource="{Binding Antonyms}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Content="{Binding}" Margin="0,0,5,5" 
                                                                    Command="{Binding DataContext.SearchRelatedCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>