<Page x:Class="Royal_Blueberry_Dictionary.View.Pages.FavouriteWordsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Royal_Blueberry_Dictionary.View.Pages"
      xmlns:uc="clr-namespace:Royal_Blueberry_Dictionary.View.User_Control"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FavouriteWordsPage"
      Background="{DynamicResource MainBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30">
        <StackPanel>
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="2"
                    CornerRadius="20"
                    Padding="40,30"
                    Margin="0,0,0,30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.1" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="⭐" FontSize="48" VerticalAlignment="Center" Foreground="{DynamicResource TextColor}" Margin="0,0,15,0" />
                            <TextBlock Text="Favourite Words"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextColor}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource ClearButtonStyle}"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,7"
                                Command="{Binding ClearAllFavoritesCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑️" FontSize="16" Margin="0,0,8,0" />
                                <TextBlock Text="Delete All" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <WrapPanel HorizontalAlignment="Left">
                        <Button Style="{StaticResource FilterChipStyle}"
                                Command="{Binding ShowAllCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="All" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource FilterChipStyle}"
                                Command="{Binding FilterByPartOfSpeechCommand}"
                                CommandParameter="noun">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Noun" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource FilterChipStyle}"
                                Command="{Binding FilterByPartOfSpeechCommand}"
                                CommandParameter="verb">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Verb" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource FilterChipStyle}"
                                Command="{Binding FilterByPartOfSpeechCommand}"
                                CommandParameter="adjective">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Adjective" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding FavoriteWords}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <uc:WordDefinitionCard DataSource="{Binding}"
                                               Margin="0,0,0,10"
                                               DeleteCommand="{Binding DataContext.FavoriteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               FavoriteCommand="{Binding DataContext.FavoriteCommand, RelativeSource={RelativeSource AncestorType=Page}}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
