<Page x:Class="Royal_Blueberry_Dictionary.View.Pages.OfflinePackagesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:uc="clr-namespace:Royal_Blueberry_Dictionary.View.User_Control"
      xmlns:conv="clr-namespace:Royal_Blueberry_Dictionary.Converters"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="1100"
      Title="OfflinePackagesPage"
      Background="{DynamicResource MainBackground}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:StringToVisibilityConverter x:Key="StrToVis"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisWpf"/>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,24">
            <StackPanel Margin="30">
                <!-- HEADER (theo CNPM OfflineModePage) -->
                <Border Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="2"
                        CornerRadius="20"
                        Padding="40,30"
                        Margin="0,0,0,30">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="📥" FontSize="48" Margin="0,0,15,0"
                                       Foreground="{DynamicResource TextColor}"/>
                            <TextBlock Text="Offline Packages"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextColor}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Tải gói từ vựng từ server về máy, mở xem bất cứ lúc nào; có thể đưa toàn bộ từ trong gói vào My Words."
                                   Foreground="{DynamicResource TextColor}"
                                   FontSize="15"
                                   Opacity="0.8"
                                   TextWrapping="Wrap"
                                   Margin="63,0,0,0"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource TextColor}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Margin="63,12,0,0"
                                   Visibility="{Binding StatusMessage, Converter={StaticResource StrToVis}}"/>
                    </StackPanel>
                </Border>

                <!-- STATS -->
                <Border Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource ButtonColor}"
                        BorderThickness="2"
                        CornerRadius="15"
                        Padding="30"
                        Margin="0,0,0,30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding DownloadedCount}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource ButtonColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Đã tải"
                                       Foreground="{DynamicResource TextColor}"
                                       FontSize="14"
                                       Opacity="0.8"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TotalWordsDisplay}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource ButtonColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Từ (ước lượng)"
                                       Foreground="{DynamicResource TextColor}"
                                       FontSize="14"
                                       Opacity="0.8"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TotalSizeDisplay}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource ButtonColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Dung lượng cache"
                                       FontSize="14"
                                       Opacity="0.8"
                                       Foreground="{DynamicResource TextColor}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding AvailableCount}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource ButtonColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Trên server"
                                       Foreground="{DynamicResource TextColor}"
                                       FontSize="14"
                                       Opacity="0.8"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- DOWNLOADED -->
                <Border Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="2"
                        CornerRadius="20"
                        Padding="30"
                        Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="✅ Đã tải về máy"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextColor}"
                                   Margin="0,0,0,20"/>

                        <ItemsControl ItemsSource="{Binding DownloadedPackages}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <uc:PackageCard Margin="8" MinWidth="360"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel HorizontalAlignment="Center"
                                    Margin="0,40,0,0"
                                    Visibility="{Binding ShowDownloadedEmpty, Converter={StaticResource BoolToVisWpf}}">
                            <TextBlock Text="📭"
                                       FontSize="60"
                                       Foreground="{DynamicResource TextColor}"
                                       HorizontalAlignment="Center"
                                       Opacity="0.5"/>
                            <TextBlock Text="Chưa có package nào được tải về"
                                       FontSize="16"
                                       Foreground="{DynamicResource TextColor}"
                                       Opacity="0.7"
                                       Margin="0,10,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- AVAILABLE -->
                <Border Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="2"
                        CornerRadius="20"
                        Padding="30">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="📦 Có trên server"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextColor}"
                                       VerticalAlignment="Center"/>
                            <Button Content="🔄 Cập nhật danh sách"
                                    Padding="14,10"
                                    Margin="20,0,0,0"
                                    Background="{DynamicResource ButtonColor}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Command="{Binding RefreshCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="10"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <TextBlock Text="Các gói chưa tải — bấm «Tải offline» trên thẻ để lưu về máy, rồi «Xem» hoặc «My Words»."
                                   FontSize="13"
                                   Opacity="0.75"
                                   Foreground="{DynamicResource TextColor}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>

                        <ItemsControl ItemsSource="{Binding AvailablePackages}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <uc:PackageCard Margin="8" MinWidth="360"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Không còn gói nào chưa tải (hoặc server chưa trả về danh sách)."
                                   FontSize="14"
                                   Opacity="0.65"
                                   Foreground="{DynamicResource TextColor}"
                                   HorizontalAlignment="Center"
                                   Margin="0,24,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AvailablePackages.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Border Background="{DynamicResource MainBackground}"
                Opacity="0.92"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Đang tải…"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextColor}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
