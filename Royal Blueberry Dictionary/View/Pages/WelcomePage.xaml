<Page x:Class="Royal_Blueberry_Dictionary.View.Pages.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:conv="clr-namespace:Royal_Blueberry_Dictionary.Converters"
      mc:Ignorable="d"
      d:DesignHeight="820"
      d:DesignWidth="1200"
      Background="{DynamicResource MainBackground}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="EntryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="58"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="18,0"/>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Border Style="{StaticResource CardStyle}" CornerRadius="30" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource NavbarBackground}"
                        CornerRadius="30,0,0,30"
                        Padding="30">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="86" Height="86" CornerRadius="22" Background="#1CFFFFFF" BorderBrush="#33FFFFFF" BorderThickness="2">
                            <TextBlock Text="BB"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Royal Blueberry"
                                   Margin="0,24,0,10"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Start with an account for synced learning, or continue in guest mode for local study on this device."
                                   FontSize="14"
                                   Foreground="White"
                                   Opacity="0.92"
                                   TextWrapping="Wrap"
                                   LineHeight="22"/>

                        <Border Margin="0,28,0,0" Padding="16,14" CornerRadius="16" Background="#1AFFFFFF" BorderBrush="#2FFFFFFF" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Dictionary search" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock Text="Look up words immediately, even before signing in."
                                           Margin="0,6,0,0"
                                           Foreground="White"
                                           Opacity="0.82"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,14,0,0" Padding="16,14" CornerRadius="16" Background="#1AFFFFFF" BorderBrush="#2FFFFFFF" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Saved progress" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock Text="Accounts unlock sync-ready auth flow and profile-based session restore."
                                           Margin="0,6,0,0"
                                           Foreground="White"
                                           Opacity="0.82"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1" Margin="42,34">
                    <StackPanel MaxWidth="560" VerticalAlignment="Center">
                        <TextBlock Text="{Binding WelcomeTitle}"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextColor}"/>

                        <TextBlock Text="{Binding WelcomeSubtitle}"
                                   Margin="0,10,0,24"
                                   FontSize="15"
                                   Foreground="{DynamicResource TextColor}"
                                   Opacity="0.8"
                                   TextWrapping="Wrap"/>

                        <Border Padding="16,14"
                                Margin="0,0,0,22"
                                CornerRadius="16"
                                Background="{DynamicResource SearchBackground}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1"
                                Visibility="{Binding HasActiveSession, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentDisplayName}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"/>
                                <TextBlock Text="{Binding CurrentEmail}"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource TextColor}"
                                           Opacity="0.74"/>
                            </StackPanel>
                        </Border>

                        <Button Command="{Binding ContinueWithPrimaryActionCommand}"
                                Style="{StaticResource SearchButtonStyle}"
                                Height="58"
                                Margin="0,0,0,14">
                            <TextBlock Text="{Binding PrimaryActionText}" FontSize="16" FontWeight="SemiBold"/>
                        </Button>

                        <Button Command="{Binding OpenLoginCommand}" Style="{StaticResource EntryActionButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding SignInText}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="Open account"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextColor}"
                                           Opacity="0.6"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <Button Command="{Binding OpenSignUpCommand}" Style="{StaticResource EntryActionButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding SignUpText}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="Create profile"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextColor}"
                                           Opacity="0.6"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <Button Command="{Binding ContinueAsGuestCommand}" Style="{StaticResource EntryActionButtonStyle}" Margin="0,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Continue as guest"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextColor}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="Local only"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextColor}"
                                           Opacity="0.6"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <TextBlock Text="Guest mode keeps the app usable locally. You can open Account later to sign in or create an account."
                                   Margin="0,22,0,0"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextColor}"
                                   Opacity="0.66"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
