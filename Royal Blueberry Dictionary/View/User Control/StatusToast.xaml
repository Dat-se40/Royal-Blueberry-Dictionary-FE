<UserControl x:Class="Royal_Blueberry_Dictionary.View.User_Control.StatusToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="360"
             d:DesignHeight="96"
             IsHitTestVisible="False">

    <UserControl.Resources>
        <Style x:Key="ToastCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F3FCF7" />
            <Setter Property="BorderBrush" Value="#A7E5C2" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsError, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    <Setter Property="Background" Value="#FFF5F5" />
                    <Setter Property="BorderBrush" Value="#F5B2B2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToastBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#1D9B5C" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsError, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    <Setter Property="Background" Value="#DC2626" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToastTitleStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="Success" />
            <Setter Property="Foreground" Value="#0F6B41" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsError, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    <Setter Property="Text" Value="Something went wrong" />
                    <Setter Property="Foreground" Value="#A61B1B" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToastMessageStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#155B3B" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsError, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    <Setter Property="Foreground" Value="#8F1D1D" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToastGlyphStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="OK" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsError, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    <Setter Property="Text" Value="!" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border x:Name="ToastCard"
            MaxWidth="360"
            Padding="14,12"
            CornerRadius="18"
            BorderThickness="1"
            Visibility="Collapsed"
            Opacity="0"
            Style="{StaticResource ToastCardStyle}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22"
                              ShadowDepth="0"
                              Opacity="0.16"
                              Color="#1E3A8A" />
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform Y="-10" />
        </Border.RenderTransform>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Width="38"
                    Height="38"
                    CornerRadius="19"
                    Style="{StaticResource ToastBadgeStyle}">
                <TextBlock Style="{StaticResource ToastGlyphStyle}"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="1"
                        Margin="12,0,0,0">
                <TextBlock Style="{StaticResource ToastTitleStyle}"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Message, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Style="{StaticResource ToastMessageStyle}"
                           Margin="0,3,0,0"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
