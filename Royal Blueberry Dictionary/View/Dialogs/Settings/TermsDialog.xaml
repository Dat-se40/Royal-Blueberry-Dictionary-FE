<Window x:Class="Royal_Blueberry_Dictionary.View.Dialogs.Settings.TermsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Terms of Service"
        Width="760" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        ResizeMode="CanResize"
        MinWidth="700" MinHeight="600"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- Header Style -->
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
        </Style>

        <!-- Body Style -->
        <Style x:Key="BodyStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="22"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>

        <!-- Section Title Style -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Close Button Style -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#667EEA" Offset="0"/>
                        <GradientStop Color="#764BA2" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="32,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#5568D3" Offset="0"/>
                                <GradientStop Color="#6A42A0" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20"
            Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.3" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    CornerRadius="18,18,0,0"
                    Padding="32,24"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#667EEA" Offset="0"/>
                        <GradientStop Color="#764BA2" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#20FFFFFF"
                                Width="64" Height="64"
                                CornerRadius="16"
                                Margin="0,0,20,0">
                            <TextBlock Text="📄"
                                       FontSize="40"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TERMS OF SERVICE"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="Terms of Service and Privacy Policy"
                                       FontSize="14"
                                       Foreground="White"
                                       Opacity="0.9"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Close Button -->
                    <Button Content="✕"
                            FontSize="24"
                            Width="40" Height="40"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#30FFFFFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24">
                <StackPanel>
                    <!-- License -->
                    <TextBlock Style="{StaticResource HeaderStyle}">
                        ⚖️ License
                    </TextBlock>

                    <Border Background="{DynamicResource SearchBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="20"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="MIT License"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <TextBlock Style="{StaticResource BodyStyle}">
                                Copyright (c) 2025 Royal Blueberry Dictionary Team
                            </TextBlock>

                            <TextBlock Style="{StaticResource BodyStyle}">
                                Permission is hereby granted, free of charge, to any person obtaining a copy of this software and associated documentation files (the "Software"), to deal in the Software without restriction, including without limitation the rights to use, copy, modify, merge, publish, distribute, sublicense, and/or sell copies of the Software.
                            </TextBlock>

                            <TextBlock Style="{StaticResource BodyStyle}" FontWeight="SemiBold">
                                THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Privacy -->
                    <TextBlock Style="{StaticResource HeaderStyle}">
                        🔒 Privacy Policy
                    </TextBlock>

                    <Border Background="{DynamicResource SearchBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="20"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="1. Collected Data"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Style="{StaticResource BodyStyle}" Margin="15,0,0,10">
                                • Vocabulary you saved (My Words)<LineBreak/>
                                • Search history<LineBreak/>
                                • App settings<LineBreak/>
                                • Google account information (if logged in)
                            </TextBlock>

                            <TextBlock Text="2. Purpose of Use"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,10,0,10"/>
                            <TextBlock Style="{StaticResource BodyStyle}" Margin="15,0,0,10">
                                • Store personal data<LineBreak/>
                                • Sync across devices<LineBreak/>
                                • Improve user experience
                            </TextBlock>

                            <TextBlock Text="3. Data Protection"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,10,0,10"/>
                            <TextBlock Style="{StaticResource BodyStyle}" Margin="15,0,0,10">
                                • Data is stored on YOUR Google Drive<LineBreak/>
                                • We do NOT collect or sell your data<LineBreak/>
                                • You have the right to delete your data at any time
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Terms of Use -->
                    <TextBlock Style="{StaticResource HeaderStyle}">
                        📋 Terms of Use
                    </TextBlock>

                    <Border Background="{DynamicResource SearchBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="20"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Style="{StaticResource BodyStyle}">
                                ✅ YOU ARE ALLOWED TO:<LineBreak/>
                                • Use the app for free<LineBreak/>
                                • Copy and distribute<LineBreak/>
                                • Modify the source code (if available)
                            </TextBlock>

                            <TextBlock Style="{StaticResource BodyStyle}" Margin="0,15,0,0">
                                ❌ YOU ARE NOT ALLOWED TO:<LineBreak/>
                                • Use it for illegal purposes<LineBreak/>
                                • Sell or commercialize it unlawfully<LineBreak/>
                                • Remove copyright and license
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Contact -->
                    <TextBlock Style="{StaticResource HeaderStyle}">
                        📧 Contact
                    </TextBlock>

                    <Border Background="{DynamicResource SearchBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Style="{StaticResource BodyStyle}">
                                If you have any questions about these terms, please contact:
                            </TextBlock>
                            <TextBlock Style="{StaticResource BodyStyle}" Margin="15,10,0,0">
                                📧 Email: labotanique117@gmail.com
                            </TextBlock>
                            <TextBlock Style="{StaticResource BodyStyle}" Margin="15,5,0,0">
                                🐙 GitHub: github.com/Dat-se40/Royal-Blueberry-Dictionary-FE
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer Buttons -->
            <Border Grid.Row="2"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="0,2,0,0"
                    CornerRadius="0,0,18,18"
                    Padding="24,16">
                <Button Content="Close"
                        Width="140"
                        Style="{StaticResource CloseButtonStyle}"
                        HorizontalAlignment="Right"
                        Click="Close_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>
