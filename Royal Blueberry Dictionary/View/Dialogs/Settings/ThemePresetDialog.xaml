<Window x:Class="Royal_Blueberry_Dictionary.View.Dialogs.Settings.ThemePresetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose Color Theme"
        Width="880"
        Height="720"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- Theme Card Button Style -->
        <Style x:Key="ThemeCardButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Padding="4">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#15667EEA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Theme Preview Card -->
        <Style x:Key="ThemePreviewCard" TargetType="Border">
            <Setter Property="Height" Value="110"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.25"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Color Strip Style -->
        <Style x:Key="ColorStrip" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="Height" Value="32"/>
        </Style>

        <!-- Theme Name Style -->
        <Style x:Key="ThemeName" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="2"
            CornerRadius="24">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.3" Color="Black"/>
        </Border.Effect>

        <Grid Margin="36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#20667EEA"
                            Width="56" Height="56"
                            CornerRadius="16"
                            Margin="0,0,16,0">
                        <TextBlock Text="🎨"
                                   FontSize="32"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Preset Color Themes"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextColor}"/>
                        <TextBlock Text="Choose from 23 beautiful themes"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextColor}"
                                   Opacity="0.7"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Button Content="✕"
                        Width="48" Height="48"
                        FontSize="24"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource TextColor}"
                        Cursor="Hand"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="Close_Click"/>
            </Grid>

            <!-- Theme Grid -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <UniformGrid Columns="4" Margin="0,0,12,0">

                    <!-- ✅ THEME 1: PASTEL DREAM -->
                    <Button Style="{StaticResource ThemeCardButton}"
                            Click="ThemeButton_Click"
                            Tag="theme1">
                        <StackPanel Width="160">
                            <Border Style="{StaticResource ThemePreviewCard}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#CDB4DB" Offset="0"/>
                                        <GradientStop Color="#A2D2FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Style="{StaticResource ColorStrip}">
                                    <Border Background="#A2D2FF" Width="53.33"/>
                                    <Border Background="#BDE0FE" Width="53.33"/>
                                    <Border Background="#CDB4DB" Width="53.33"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Pastel Dream" Style="{StaticResource ThemeName}"/>
                        </StackPanel>
                    </Button>

                    <!-- ✅ THEME 2: LAVENDER MIST -->
                    <Button Style="{StaticResource ThemeCardButton}"
                            Click="ThemeButton_Click"
                            Tag="theme2">
                        <StackPanel Width="160">
                            <Border Style="{StaticResource ThemePreviewCard}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#B8C0FF" Offset="0"/>
                                        <GradientStop Color="#E7C6FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Style="{StaticResource ColorStrip}">
                                    <Border Background="#C8B6FF" Width="53.33"/>
                                    <Border Background="#E7C6FF" Width="53.33"/>
                                    <Border Background="#B8C0FF" Width="53.33"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Lavender Mist" Style="{StaticResource ThemeName}"/>
                        </StackPanel>
                    </Button>

                    <!-- TODO: Áp dụng tương tự cho 21 theme còn lại -->
                    <!-- Tôi đã tối ưu style, bạn chỉ cần copy-paste và đổi màu + tag -->

                </UniformGrid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>