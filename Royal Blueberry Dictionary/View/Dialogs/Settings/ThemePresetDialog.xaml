                                    <Border Height="96" CornerRadius="14">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.22"/>
                                        </Border.Effect>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#CDB4DB" Offset="0"/>
                                                <GradientStop Color="#A2D2FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid VerticalAlignment="Bottom" Height="26">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#A2D2FF" CornerRadius="0,0,0,10"/>
                                            <Border Grid.Column="1" Background="#BDE0FE"/>
                                            <Border Grid.Column="2" Background="#CDB4DB" CornerRadius="0,0,10,0"/>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="Pastel Dream" Style="{StaticResource ThemeNameStyle}"/>
