<Window x:Class="Royal_Blueberry_Dictionary.View.Dialogs.Settings.CustomThemeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="Custom Theme"
        Width="560"
        Height="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <DropShadowEffect x:Key="DialogShadow"
                          BlurRadius="28"
                          ShadowDepth="0"
                          Opacity="0.16"
                          Color="#12285D"/>

        <Style x:Key="HeaderIconWrapStyle" TargetType="Border">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="#EEF4FF"/>
            <Setter Property="BorderBrush" Value="#D7E3FF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#FFF5F5"/>
            <Setter Property="Foreground" Value="#B42318"/>
            <Setter Property="BorderBrush" Value="#FFD6D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E5484D"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorRowContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="#FBFDFF"/>
            <Setter Property="BorderBrush" Value="#D8E4FF"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="ApplyButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource ButtonColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.84"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonColor}"/>
            <Setter Property="Background" Value="#F7FAFF"/>
            <Setter Property="BorderBrush" Value="#C8D7FF"/>
            <Setter Property="BorderThickness" Value="1.4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EEF4FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho ColorPicker nhìn giống nút Choose -->
        <Style x:Key="PickerAsButtonStyle" TargetType="xctk:ColorPicker">
            <Setter Property="Width" Value="92"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonColor}"/>
            <Setter Property="Background" Value="#F2F7FF"/>
            <Setter Property="BorderBrush" Value="#C8D7FF"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="ShowStandardColors" Value="True"/>
            <Setter Property="ShowRecentColors" Value="True"/>
            <Setter Property="UsingAlphaChannel" Value="False"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Margin="8,8,8,8"
                Background="#F8FBFF"
                BorderBrush="#C8D7FF"
                BorderThickness="1"
                CornerRadius="24"
                Effect="{StaticResource DialogShadow}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource HeaderIconWrapStyle}">
                            <TextBlock Text="🎨"
                                       FontSize="21"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Create Custom Theme"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextColor}"/>
                            <TextBlock Text="Choose three colors and personalize the app."
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextColor}"
                                       Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="✕"
                            Style="{StaticResource CloseButtonStyle}"
                            Click="Close_Click"/>
                </Grid>

                <!-- TIP -->
                <Border Grid.Row="1"
                        Background="#EEF4FF"
                        BorderBrush="#D7E3FF"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14,10"
                        Margin="0,0,0,18">
                    <TextBlock Text="A good palette usually has one main color, one softer secondary color, and one accent color for emphasis."
                               FontSize="12"
                               Foreground="{DynamicResource TextColor}"
                               Opacity="0.78"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- BODY -->
                <StackPanel Grid.Row="2">
                    <!-- Primary -->
                    <StackPanel Margin="0,0,0,6">
                        <TextBlock Text="Primary color"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"/>
                        <TextBlock Text="Main color for buttons and active elements"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextColor}"
                                   Opacity="0.65"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Style="{StaticResource ColorRowContainerStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="PrimaryColorButton"
                                    Width="38"
                                    Height="38"
                                    Margin="0,0,12,0"
                                    Background="#667EEA"
                                    BorderBrush="#C8D7FF"
                                    BorderThickness="1.5"
                                    Cursor="Hand"
                                    Click="PrimaryColorButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="10"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBlock x:Name="PrimaryHexText"
                                       Grid.Column="1"
                                       Text="#667EEA"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ButtonColor}"/>

                            <xctk:ColorPicker Grid.Column="2"
                                              x:Name="PrimaryColorPicker"
                                              Style="{StaticResource PickerAsButtonStyle}"
                                              SelectedColorChanged="PrimaryColorPicker_SelectedColorChanged"
                                              SelectedColor="#667EEA"/>
                        </Grid>
                    </Border>

                    <!-- Secondary -->
                    <StackPanel Margin="0,0,0,6">
                        <TextBlock Text="Secondary color"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"/>
                        <TextBlock Text="Soft supporting color for gradients and surfaces"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextColor}"
                                   Opacity="0.65"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Style="{StaticResource ColorRowContainerStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="SecondaryColorButton"
                                    Width="38"
                                    Height="38"
                                    Margin="0,0,12,0"
                                    Background="#8B9DFF"
                                    BorderBrush="#C8D7FF"
                                    BorderThickness="1.5"
                                    Cursor="Hand"
                                    Click="SecondaryColorButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="10"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBlock x:Name="SecondaryHexText"
                                       Grid.Column="1"
                                       Text="#8B9DFF"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ButtonColor}"/>

                            <xctk:ColorPicker Grid.Column="2"
                                              x:Name="SecondaryColorPicker"
                                              Style="{StaticResource PickerAsButtonStyle}"
                                              SelectedColorChanged="SecondaryColorPicker_SelectedColorChanged"
                                              SelectedColor="#8B9DFF"/>
                        </Grid>
                    </Border>

                    <!-- Accent -->
                    <StackPanel Margin="0,0,0,6">
                        <TextBlock Text="Accent color"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"/>
                        <TextBlock Text="Highlight color for emphasis and special details"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextColor}"
                                   Opacity="0.65"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Style="{StaticResource ColorRowContainerStyle}" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="AccentColorButton"
                                    Width="38"
                                    Height="38"
                                    Margin="0,0,12,0"
                                    Background="#F093FB"
                                    BorderBrush="#C8D7FF"
                                    BorderThickness="1.5"
                                    Cursor="Hand"
                                    Click="AccentColorButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="10"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBlock x:Name="AccentHexText"
                                       Grid.Column="1"
                                       Text="#F093FB"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ButtonColor}"/>

                            <xctk:ColorPicker Grid.Column="2"
                                              x:Name="AccentColorPicker"
                                              Style="{StaticResource PickerAsButtonStyle}"
                                              SelectedColorChanged="AccentColorPicker_SelectedColorChanged"
                                              SelectedColor="#F093FB"/>
                        </Grid>
                    </Border>

                    <!-- preview -->
                    <Border Background="#FBFDFF"
                            BorderBrush="#D8E4FF"
                            BorderThickness="1.4"
                            CornerRadius="16"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="Preview"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextColor}"/>
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="PrimaryPreview"
                                        Grid.Column="0"
                                        Height="42"
                                        Margin="0,0,8,0"
                                        CornerRadius="12"
                                        Background="#667EEA"/>

                                <Border x:Name="SecondaryPreview"
                                        Grid.Column="1"
                                        Height="42"
                                        Margin="0,0,8,0"
                                        CornerRadius="12"
                                        Background="#8B9DFF"/>

                                <Border x:Name="AccentPreview"
                                        Grid.Column="2"
                                        Height="42"
                                        CornerRadius="12"
                                        Background="#F093FB"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- FOOTER -->
                <Grid Grid.Row="3" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Your selected colors will be applied immediately."
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource TextColor}"
                               Opacity="0.68"/>

                    <Button Grid.Column="1"
                            Content="Cancel"
                            Margin="0,0,10,0"
                            Style="{StaticResource CancelButtonStyle}"
                            Click="Close_Click"/>

                    <Button Grid.Column="2"
                            Content="Apply Theme"
                            Style="{StaticResource ApplyButtonStyle}"
                            Click="Apply_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
