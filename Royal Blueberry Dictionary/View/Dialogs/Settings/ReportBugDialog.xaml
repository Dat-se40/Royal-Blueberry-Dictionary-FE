<Window x:Class="Royal_Blueberry_Dictionary.View.Dialogs.Settings.ReportBugDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Report a Bug"
        Width="700" Height="680"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        ResizeMode="CanResize"
        MinWidth="650" MinHeight="600"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- Header Style -->
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Body Style -->
        <Style x:Key="BodyStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="22"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>

        <!-- Section Title Style -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#667EEA" Offset="0"/>
                        <GradientStop Color="#764BA2" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#5568D3" Offset="0"/>
                                <GradientStop Color="#6A42A0" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Close Button Style -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#667EEA" Offset="0"/>
                        <GradientStop Color="#764BA2" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="32,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#5568D3" Offset="0"/>
                                <GradientStop Color="#6A42A0" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20"
            Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.3" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    CornerRadius="18,18,0,0"
                    Padding="32,24"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#667EEA" Offset="0"/>
                        <GradientStop Color="#764BA2" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#20FFFFFF"
                                Width="64" Height="64"
                                CornerRadius="16"
                                Margin="0,0,20,0">
                            <TextBlock Text="🐛"
                                       FontSize="40"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="REPORT A BUG"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="Help us improve the app"
                                       FontSize="14"
                                       Foreground="White"
                                       Opacity="0.9"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Close Button -->
                    <Button Content="✕"
                            FontSize="24"
                            Width="40" Height="40"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#30FFFFFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24">
                <StackPanel>
                    <!-- Intro -->
                    <TextBlock Style="{StaticResource BodyStyle}">
                        Please provide as much information as possible so we can quickly identify and resolve the issue.
                    </TextBlock>

                    <!-- What to include -->
                    <TextBlock Style="{StaticResource HeaderStyle}" Margin="0,15,0,10">
                        📝 Information to Provide
                    </TextBlock>

                    <Border Background="{DynamicResource SearchBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="20"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="1️⃣ Detailed error description"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Style="{StaticResource BodyStyle}"
                                       Margin="15,5,0,10">
                                • Where did the error occur? (Which page or feature?)<LineBreak/>
                                • What happened? (Crash, unresponsive, incorrect display, etc.)
                            </TextBlock>

                            <TextBlock Text="2️⃣ Steps to reproduce the issue"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,10,0,0"/>
                            <TextBlock Style="{StaticResource BodyStyle}"
                                       Margin="15,5,0,10">
                                • Step 1: Open page X<LineBreak/>
                                • Step 2: Click the Y button<LineBreak/>
                                • Step 3: The error appears
                            </TextBlock>

                            <TextBlock Text="3️⃣ Screenshot (if any)"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,10,0,0"/>
                            <TextBlock Style="{StaticResource BodyStyle}"
                                       Margin="15,5,0,10">
                                • Take a screenshot of the error<LineBreak/>
                                • Attach it in the email or GitHub Issue
                            </TextBlock>

                            <TextBlock Text="4️⃣ System Information"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,10,0,0"/>
                            <TextBlock Style="{StaticResource BodyStyle}"
                                       Margin="15,5,0,10">
                                • Windows version: 10/11<LineBreak/>
                                • App version: 1.0.0
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- How to report -->
                    <TextBlock Style="{StaticResource HeaderStyle}" Margin="0,10,0,10">
                        📬 How to Submit a Report
                    </TextBlock>

                    <!-- Option 1: GitHub -->
                    <Border Background="{DynamicResource SearchBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="20"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="✅ GitHub Issues (Recommended)"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextColor}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Style="{StaticResource BodyStyle}">
                                • Open and transparent<LineBreak/>
                                • Track fix progress in real-time<LineBreak/>
                                • Community can provide support
                            </TextBlock>
                            <Button Content="🐙 Open GitHub Issues"
                                    Style="{StaticResource ActionButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Click="OpenGitHubIssues_Click"
                                    Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Option 2: Email -->
                    <Border Background="{DynamicResource SearchBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="📧 Email"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextColor}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Style="{StaticResource BodyStyle}">
                                • More private<LineBreak/>
                                • Suitable for personal issues<LineBreak/>
                                • Email: labotanique117@gmail.com
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer Buttons -->
            <Border Grid.Row="2"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="0,2,0,0"
                    CornerRadius="0,0,18,18"
                    Padding="24,16">
                <Button Content="Close"
                        Width="140"
                        Style="{StaticResource CloseButtonStyle}"
                        HorizontalAlignment="Right"
                        Click="Close_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>