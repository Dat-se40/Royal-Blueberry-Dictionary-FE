<Window x:Class="Royal_Blueberry_Dictionary.View.Dialogs.PackageDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:Royal_Blueberry_Dictionary.Converters"
        mc:Ignorable="d"
        Title="Vocabulary Package Details"
        Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MainBackground}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="2"
            CornerRadius="20"
            Margin="20"
            Padding="30"
            Background="{DynamicResource CardBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="{Binding PackageName}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextColor}"/>
                    <Border Background="{DynamicResource ButtonColor}"
                            CornerRadius="15"
                            Padding="12,5"
                            Margin="15,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding TotalWordsCount}"
                                   Foreground="White"
                                   FontWeight="Bold"/>
                    </Border>
                </StackPanel>

                <TextBlock Text="{Binding PackageDescription}"
                           FontSize="14"
                           Opacity="0.8"
                           Foreground="{DynamicResource TextColor}"/>

                <!-- Search Box -->
                <Border Background="{DynamicResource SearchBackground}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="2"
                        CornerRadius="12"
                        Padding="15"
                        Margin="0,15,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextColor}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1"
                                Content="🔍 Search"
                                Padding="15,8"
                                Background="{DynamicResource ButtonColor}"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding SearchCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- WORD LIST -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredWords}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource WordItemBackground}"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="15"
                                    Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Word Info -->
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <TextBlock Text="{Binding Word}"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TextColor}"
                                                       Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding Phonetic}"
                                                       FontSize="14"
                                                       Opacity="0.7"
                                                       Foreground="{DynamicResource TextColor}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding ShortDefinition}"
                                                   FontSize="13"
                                                   Opacity="0.8"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextColor}"/>
                                    </StackPanel>

                                    <!-- Placeholder column kept for layout balance -->
                                    <Border Grid.Column="1" Width="0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- FOOTER -->
            <StackPanel Grid.Row="2" Margin="0,20,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="❌ Close"
                            Padding="0,14"
                            Margin="0,0,10,0"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Background="Transparent"
                            Foreground="#DC2626"
                            BorderBrush="#DC2626"
                            BorderThickness="2"
                            Cursor="Hand"
                            Click="CancelButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="12"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="1"
                            Padding="0,14"
                            Margin="10,0,0,0"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Background="{DynamicResource ButtonColor}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding CloseCommand}">
                        <Button.Content>
                            <TextBlock Text="OK"/>
                        </Button.Content>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="12"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
