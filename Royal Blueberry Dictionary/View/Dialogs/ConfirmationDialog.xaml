<Window x:Class="Royal_Blueberry_Dictionary.View.Dialogs.ConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Confirmation"
        Width="430"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Grid Background="Transparent">
        <Border MaxWidth="430"
                Margin="18"
                Padding="0"
                CornerRadius="20"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1.5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22"
                                  ShadowDepth="0"
                                  Opacity="0.18"
                                  Color="#12285D" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="18,16,18,12"
                        Background="Transparent"
                        CornerRadius="20,20,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding TitleText}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextColor}"
                                   VerticalAlignment="Center" />

                        <Button Grid.Column="1"
                                Width="30"
                                Height="30"
                                Background="#F3F6FF"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1"
                                Cursor="Hand"
                                Click="CloseButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CloseBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="9">
                                        <TextBlock Text="X"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource ButtonColor}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CloseBorder" Property="Background" Value="#E8EEFF" />
                                            <Setter TargetName="CloseBorder" Property="BorderBrush" Value="{DynamicResource ButtonColor}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Margin="18,6,18,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Width="54"
                          Height="54"
                          Margin="0,0,14,0">
                        <Ellipse Fill="#FFF9FAFC"
                                 Stroke="#D7E2FF"
                                 StrokeThickness="1.5" />
                        <Ellipse Width="34"
                                 Height="34"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FEE8E8" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDanger}" Value="False">
                                            <Setter Property="Fill" Value="#E4EEFF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="?"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#DC2626" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDanger}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource ButtonColor}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding HeadingText}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextColor}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding MessageText}"
                                   Margin="0,6,0,0"
                                   FontSize="13"
                                   LineHeight="20"
                                   Foreground="{DynamicResource TextColor}"
                                   Opacity="0.78"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2"
                      Margin="18,0,18,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            MinWidth="118"
                            Height="44"
                            Margin="0,0,12,0"
                            Padding="18,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            IsCancel="True"
                            Click="SecondaryButton_Click">
                        <TextBlock Text="{Binding SecondaryButtonText}"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                    </Button>

                    <Button x:Name="PrimaryActionButton"
                            Grid.Column="2"
                            MinWidth="118"
                            Height="44"
                            Padding="18,0"
                            Style="{StaticResource DangerButtonStyle}"
                            IsDefault="True"
                            Click="PrimaryButton_Click">
                        <TextBlock Text="{Binding PrimaryButtonText}"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
